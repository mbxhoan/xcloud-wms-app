# Release signing config — COPY to `keystore.properties` and fill in real values.
# `keystore.properties` is git-ignored. NEVER commit it or the .jks/.keystore file.
#
# How to create a keystore once (keep it forever — losing it blocks future updates):
#   keytool -genkeypair -v \
#     -keystore xcloud-wms-release.jks \
#     -alias xcloud-wms \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# Store the .jks and the passwords in the company password manager / secret vault.
# Recommended: keep the .jks OUTSIDE the repo and point storeFile at an absolute path.

# Path to the keystore file. Relative paths resolve from app/android/.
# Prefer an absolute path outside the repo, e.g. /Users/you/secrets/xcloud-wms-release.jks
storeFile=../secrets/xcloud-wms-release.jks
storePassword=CHANGE_ME
keyAlias=xcloud-wms
keyPassword=CHANGE_ME
